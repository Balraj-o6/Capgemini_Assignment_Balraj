<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> 
        <!-- bean definitions here -->
	 <context:annotation-config></context:annotation-config>
	 <context:component-scan base-package="com"></context:component-scan>
	 <context:property-placeholder location="classpath:data.properties"/>
	 
	 
	 
	 
	  <bean id="emp1" class="com.cg.sbuList.Employee">
    <property name="empId" value="100"/>
    <property name="empName" value="Rama"/>
    <property name="salary" value="12345.67"/>
</bean>

<bean id="emp2" class="com.cg.sbuList.Employee">
    <property name="empId" value="101"/>
    <property name="empName" value="Krishna"/>
    <property name="salary" value="22345.67"/>
</bean>

<bean id="sbuList" class="com.cg.sbuList.SBU">
    <property name="sbuCode" value="10"/>
    <property name="sbuName" value="PES"/>
    <property name="sbuHead" value="Ram Kumar"/>

    <property name="empList">
        <list>
            <ref bean="emp1"/>
            <ref bean="emp2"/>
        </list>
    </property>
</bean>





<bean id="emp3" class="com.cg.collection.Employee">
    <constructor-arg index="0" value="100"/>
    <constructor-arg index="1" value="Rama"/>
    <constructor-arg index="2" value="12345.67"/>
</bean>

<bean id="emp4" class="com.cg.collection.Employee">
    <constructor-arg index="0" value="101"/>
    <constructor-arg index="1" value="Balraj"/>
    <constructor-arg index="2" value="42345.67"/>
</bean>

<bean id="empDao" class="com.cg.collection.EmployeeDAO">
    <property name="empMap">
        <map>
            <entry key="100" value-ref="emp3"/>
            <entry key="101" value-ref="emp4"/>
        </map>
    </property>
</bean>

<bean id="empService" class="com.cg.collection.EmployeeService"
      autowire="byType"/>
	
</beans>